# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-here

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=radiant_health

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# Service Configuration
SERVICE_PORT=5001
SERVICE_HOST=0.0.0.0
LOG_LEVEL=INFO

# Model Configuration
MIN_TRAINING_DATA_DAYS=30
MODEL_TRAINING_TIMEOUT=300
MODEL_CONFIDENCE_THRESHOLD=60

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# OpenAI Configuration (for fallback)
OPENAI_API_KEY=your-openai-api-key-here

# Security
ENCRYPTION_KEY=your-encryption-key-here
JWT_SECRET=your-jwt-secret-here

# Feature Flags
ENABLE_SELF_TRAINED_AI=True
ENABLE_OFFLINE_MODE=True
ENABLE_PRIVACY_ENCRYPTION=True
